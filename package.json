{
  "name": "claude-multi",
  "version": "1.17.0",
  "description": "Run Claude Code with multiple accounts and auto-switch when one hits its usage limit.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "pty-host": "node src/pty-host.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "keywords": [
    "claude",
    "claude-code",
    "electron",
    "multi-account",
    "terminal",
    "usage-limit",
    "anthropic"
  ],
  "author": "Chaman Raj (https://github.com/Chamanrajragu)",
  "license": "MIT",
  "homepage": "https://github.com/Chamanrajragu/claude-multi#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chamanrajragu/claude-multi.git"
  },
  "bugs": {
    "url": "https://github.com/Chamanrajragu/claude-multi/issues"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.206",
    "@lydell/node-pty": "^1.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "dompurify": "^3.4.11",
    "marked": "^18.0.6"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.purffle.claudemulti",
    "productName": "Claude Multi",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Development"
    }
  }
}
